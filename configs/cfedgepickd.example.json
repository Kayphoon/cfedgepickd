{
  "cloudflared": {
    "binary": "cloudflared",
    "service": "cloudflared",
    "config_path": "/etc/cloudflared/config.yml",
    "protocol": "auto",
    "metrics_url": "http://127.0.0.1:20241/metrics",
    "ready_url": "http://127.0.0.1:20241/ready",
    "systemctl": "systemctl"
  },
  "edge": {
    "port": 7844,
    "hostnames": [
      "region1.v2.argotunnel.com",
      "region2.v2.argotunnel.com",
      "us-region1.v2.argotunnel.com",
      "us-region2.v2.argotunnel.com"
    ],
    "candidate_file": "/opt/cftunnel/ip.txt",
    "candidates": [
      "198.41.192.0/24",
      "198.41.193.0/24",
      "198.41.194.0/24",
      "198.41.195.0/24",
      "198.41.196.0/24",
      "198.41.197.0/24",
      "198.41.198.0/24",
      "198.41.199.0/24",
      "198.41.200.0/24"
    ],
    "top_n": 4,
    "probe_rounds": 8,
    "probe_timeout": "800ms",
    "concurrency": 128,
    "max_candidates": 4096,
    "server_name": "quic.cftunnel.com"
  },
  "switching": {
    "probe_interval_seconds": 300,
    "metrics_poll_seconds": 5,
    "idle_window_seconds": 180,
    "cooldown_seconds": 3600,
    "restart_timeout_seconds": 30,
    "min_improvement_ratio": 0.35,
    "degraded_factor": 3,
    "degraded_rounds": 3,
    "allow_emergency_switch": true,
    "require_idle_for_planned": true,
    "apply_protocol_to_config": true
  },
  "runtime": {
    "hosts_file": "/etc/hosts",
    "backup_dir": "/var/backups/cfedgepickd",
    "state_file": "/var/lib/cfedgepickd/state.json",
    "history_file": "/var/lib/cfedgepickd/history.jsonl",
    "history_retention_days": 30,
    "log_level": "info",
    "dry_run": true
  }
}
